# Database
DB_URL=jdbc:mysql://localhost:3306/e_voting_system?useUnicode=true&characterEncoding=UTF-8&useSSL=false&serverTimezone=Asia/Ho_Chi_Minh&allowPublicKeyRetrieval=true
DB_USERNAME=root
DB_PASSWORD=change-me-to-a-strong-password
MYSQL_ROOT_PASSWORD=change-me-to-a-strong-password
MYSQL_DATABASE=e_voting_system

# JWT
JWT_SECRET=change-me-to-a-random-256bit-secret-key-here

# Mail (Gmail App Password)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=your-email@gmail.com
MAIL_PASS=your-app-password

# Cloudinary
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Service URLs
AUTH_SERVICE_URL=http://localhost:8081
VOTER_SERVICE_URL=http://localhost:8082
ELECTION_SERVICE_URL=http://localhost:8083
CRYPTO_SERVICE_URL=http://localhost:8084
AUDIT_SERVICE_URL=http://localhost:8085/api/audit/log
AUDIT_SERVICE_BASE_URL=http://localhost:8085
NOTIFICATION_SERVICE_BASE_URL=http://localhost:8086

# Gateway
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
INTERNAL_SERVICE_TOKEN=change-me-to-a-random-token-for-inter-service-auth

# Frontend
FRONTEND_URL=http://localhost:5173
WEBSOCKET_ALLOWED_ORIGIN_PATTERNS=http://localhost:5173,http://127.0.0.1:5173
